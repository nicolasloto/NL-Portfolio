<section
  id="contact"
  class="bg-white/80 backdrop-blur-lg rounded-3xl p-8 shadow-xl border border-white/30"
>
  <h3 class="text-2xl font-semibold text-white mb-6">Get in Touch</h3>

  <div class="grid md:grid-cols-[1.35fr_0.95fr] gap-8 items-start">
    <form
      id="contact-form"
      action="/api/contact"
      method="POST"
      class="space-y-6"
      novalidate
    >
      <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" />

      <div>
        <label
          for="name"
          class="block text-sm font-medium text-white/85 mb-2"
        >
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/20 focus:border-cyan-300 focus:ring-2 focus:ring-cyan-300/20 placeholder:text-white/45"
          placeholder="Your name"
          minlength="2"
          maxlength="120"
          pattern="^[A-Za-zÀ-ÿ0-9.'\-\s]{2,120}$"
          title="Please use 2-120 valid characters."
          required
        />
      </div>

      <div>
        <label
          for="email"
          class="block text-sm font-medium text-white/85 mb-2"
        >
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/20 focus:border-cyan-300 focus:ring-2 focus:ring-cyan-300/20 placeholder:text-white/45"
          placeholder="your@email.com"
          maxlength="200"
          inputmode="email"
          autocapitalize="off"
          spellcheck="false"
          required
        />
        <div id="email-suggestions" class="hidden mt-2 flex-wrap gap-2">
          <button type="button" data-domain="gmail.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/20 text-white/75 hover:text-white hover:border-cyan-300/60 transition-colors">gmail.com</button>
          <button type="button" data-domain="outlook.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/20 text-white/75 hover:text-white hover:border-cyan-300/60 transition-colors">outlook.com</button>
          <button type="button" data-domain="hotmail.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/20 text-white/75 hover:text-white hover:border-cyan-300/60 transition-colors">hotmail.com</button>
          <button type="button" data-domain="icloud.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/20 text-white/75 hover:text-white hover:border-cyan-300/60 transition-colors">icloud.com</button>
        </div>
      </div>

      <div>
        <label
          for="message"
          class="block text-sm font-medium text-white/85 mb-2"
        >
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/20 focus:border-cyan-300 focus:ring-2 focus:ring-cyan-300/20 resize-none placeholder:text-white/45"
          placeholder="Your message..."
          minlength="10"
          maxlength="5000"
          required></textarea>
      </div>

      <div class="mt-6">
        <button
          type="submit"
          class="w-full bg-gradient-to-r from-cyan-900 via-indigo-900 to-fuchsia-900 text-white font-medium px-6 py-3 rounded-xl border border-white/20 shadow-[0_8px_20px_rgba(0,0,0,0.25)]"
        >
          Send Message
        </button>
      </div>
    </form>

    <div class="w-full md:max-w-[26rem] md:justify-self-end flex flex-col gap-4">
      <div class="hover-accent-card bg-white/10 rounded-2xl p-6 border border-white/20">
        <h4 class="text-lg font-medium text-white mb-4">
          Contact Information
        </h4>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 flex items-center justify-center bg-white/10 border border-white/20 rounded-full"
              aria-label="Email"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"
                ></path>
                <path
                  d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"
                ></path>
              </svg>
            </div>
            <a
              href="mailto:lotohectornicolas@gmail.com"
              class="text-white/75 hover:text-cyan-200 transition-colors"
            >
              lotohectornicolas@gmail.com
            </a>
          </div>

          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 flex items-center justify-center bg-white/10 border border-white/20 rounded-full"
              aria-label="Phone"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  fill-rule="evenodd"
                  d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <a
              href="tel:+5493855374055"
              class="text-white/75 hover:text-fuchsia-200 transition-colors"
            >
              +54 9 348 467-0283
            </a>
          </div>

          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 flex items-center justify-center bg-white/10 border border-white/20 rounded-full"
              aria-label="Location"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white/75">Buenos Aires, Argentina</span>
          </div>
        </div>
      </div>

      <div class="hover-accent-card bg-white/10 rounded-2xl p-6 border border-white/20">
        <h4 class="text-lg font-medium text-white mb-4">Availability</h4>
        <div class="space-y-2 text-white/75">
          <p>Monday - Friday</p>
          <p class="font-medium text-white">07:00 - 23:00 (GMT -3)</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById("contact-form");
    if (!(form instanceof HTMLFormElement)) return;

    const nameInput = form.querySelector("#name");
    const emailInput = form.querySelector("#email");
    const emailSuggestions = form.querySelector("#email-suggestions");
    const messageInput = form.querySelector("#message");

    if (!(nameInput instanceof HTMLInputElement)) return;
    if (!(emailInput instanceof HTMLInputElement)) return;
    if (!(messageInput instanceof HTMLTextAreaElement)) return;

    const setNameMessage = () => {
      if (nameInput.validity.valueMissing) {
        nameInput.setCustomValidity("Please enter your name.");
      } else if (nameInput.validity.tooShort || nameInput.validity.patternMismatch) {
        nameInput.setCustomValidity("Use 2-120 valid characters for your name.");
      } else {
        nameInput.setCustomValidity("");
      }
    };

    const setEmailMessage = () => {
      if (emailInput.validity.valueMissing) {
        emailInput.setCustomValidity("Please enter your email.");
      } else if (emailInput.validity.typeMismatch) {
        emailInput.setCustomValidity("Please enter a valid email address.");
      } else {
        emailInput.setCustomValidity("");
      }
    };

    const updateEmailSuggestions = () => {
      if (!(emailSuggestions instanceof HTMLElement)) return;
      const value = emailInput.value.trim();
      const hasAt = value.includes("@");
      const [localPart, domainPart] = value.split("@");
      const show = localPart && (!hasAt || !domainPart);
      emailSuggestions.classList.toggle("hidden", !show);
      emailSuggestions.classList.toggle("flex", !!show);
    };

    const applyDomainSuggestion = (domain) => {
      const value = emailInput.value.trim();
      const localPart = value.split("@")[0]?.trim();
      if (!localPart) return;
      emailInput.value = `${localPart}@${domain}`;
      emailInput.focus();
      emailInput.setSelectionRange(emailInput.value.length, emailInput.value.length);
      setEmailMessage();
      updateEmailSuggestions();
    };

    const setMessageText = () => {
      if (messageInput.validity.valueMissing) {
        messageInput.setCustomValidity("Please add a message.");
      } else if (messageInput.validity.tooShort) {
        messageInput.setCustomValidity("Message must be at least 10 characters.");
      } else {
        messageInput.setCustomValidity("");
      }
    };

    nameInput.addEventListener("input", setNameMessage);
    emailInput.addEventListener("input", () => {
      setEmailMessage();
      updateEmailSuggestions();
    });
    emailInput.addEventListener("blur", updateEmailSuggestions);
    messageInput.addEventListener("input", setMessageText);

    if (emailSuggestions instanceof HTMLElement) {
      emailSuggestions.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest("button[data-domain]");
        if (!(button instanceof HTMLButtonElement)) return;
        const domain = button.dataset.domain;
        if (!domain) return;
        applyDomainSuggestion(domain);
      });
    }

    form.addEventListener("submit", (event) => {
      setNameMessage();
      setEmailMessage();
      setMessageText();
      if (!form.checkValidity()) {
        event.preventDefault();
        form.reportValidity();
      }
    });

    updateEmailSuggestions();
  })();
</script>
