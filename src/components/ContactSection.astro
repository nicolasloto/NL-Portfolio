<section
  id="contact"
  class="surface-panel js-foil backdrop-blur-lg rounded-3xl p-8 shadow-xl border border-white/30"
>
  <h3 class="text-2xl font-semibold text-white mb-6">Get in Touch</h3>

  <div class="grid md:grid-cols-[1.35fr_0.95fr] gap-8 items-start">
    <form
      id="contact-form"
      action="/api/contact"
      method="POST"
      class="space-y-6"
      novalidate
    >
      <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" />

      <div>
        <label
          for="name"
          class="block text-sm font-medium text-white/90 mb-2"
        >
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          class="field-control w-full px-4 py-3 text-white placeholder:text-white/60"
          placeholder="Your name"
          minlength="2"
          maxlength="120"
          pattern="^[A-Za-zŔ-˙0-9.'\-\s]{2,120}$"
          title="Please use 2-120 valid characters."
          required
        />
      </div>

      <div>
        <label
          for="email"
          class="block text-sm font-medium text-white/90 mb-2"
        >
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          class="field-control w-full px-4 py-3 text-white placeholder:text-white/60"
          placeholder="your@email.com"
          maxlength="200"
          inputmode="email"
          autocapitalize="off"
          spellcheck="false"
          required
        />
        <div id="email-suggestions" class="hidden mt-2 flex-wrap gap-2">
          <button type="button" data-domain="gmail.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-cyan-200/70 focus-visible:ring-2 focus-visible:ring-cyan-200/40 transition-colors">gmail.com</button>
          <button type="button" data-domain="outlook.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-cyan-200/70 focus-visible:ring-2 focus-visible:ring-cyan-200/40 transition-colors">outlook.com</button>
          <button type="button" data-domain="hotmail.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-cyan-200/70 focus-visible:ring-2 focus-visible:ring-cyan-200/40 transition-colors">hotmail.com</button>
          <button type="button" data-domain="icloud.com" class="px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-cyan-200/70 focus-visible:ring-2 focus-visible:ring-cyan-200/40 transition-colors">icloud.com</button>
        </div>
      </div>

      <div>
        <label
          for="message"
          class="block text-sm font-medium text-white/90 mb-2"
        >
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          class="field-control w-full px-4 py-3 text-white placeholder:text-white/60 resize-none"
          placeholder="Your message..."
          minlength="10"
          maxlength="5000"
          required></textarea>
      </div>

      <div class="mt-6">
        <button
          type="submit"
          data-idle-label="Send Message"
          data-loading-label="Sending..."
          class="w-full bg-gradient-to-r from-cyan-900 via-indigo-900 to-fuchsia-900 text-white font-medium px-6 py-3 rounded-xl border border-white/20 shadow-[0_8px_20px_rgba(0,0,0,0.25)] focus-visible:ring-2 focus-visible:ring-cyan-200/40"
        >
          Send Message
        </button>
        <p id="contact-feedback" class="mt-3 text-sm text-white/80 min-h-5" role="status" aria-live="polite" aria-atomic="true"></p>
      </div>
    </form>

    <div class="w-full md:max-w-[26rem] md:justify-self-end flex flex-col gap-4">
      <div class="hover-accent-card js-foil surface-card rounded-2xl p-6 border border-white/20">
        <h4 class="text-lg font-medium text-white mb-4">
          Contact Information
        </h4>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <div
              class="info-icon-chip"
              aria-label="Email"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"
                ></path>
                <path
                  d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"
                ></path>
              </svg>
            </div>
            <a
              href="mailto:lotohectornicolas@gmail.com"
              class="text-white/75 hover:text-cyan-200 transition-colors"
            >
              lotohectornicolas@gmail.com
            </a>
          </div>

          <div class="flex items-center gap-3">
            <div
              class="info-icon-chip"
              aria-label="Phone"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  fill-rule="evenodd"
                  d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <a
              href="tel:+5493855374055"
              class="text-white/75 hover:text-fuchsia-200 transition-colors"
            >
              +54 9 348 467-0283
            </a>
          </div>

          <div class="flex items-center gap-3">
            <div
              class="info-icon-chip"
              aria-label="Location"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white/75">Buenos Aires, Argentina</span>
          </div>
        </div>
      </div>

      <div class="hover-accent-card js-foil surface-card rounded-2xl p-6 border border-white/20">
        <h4 class="text-lg font-medium text-white mb-4">Availability</h4>
        <div class="space-y-2 text-white/75">
          <p>Monday - Friday</p>
          <p class="font-medium text-white">07:00 - 23:00 (GMT -3)</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  import { initContactForm } from "../scripts/contactForm";
  initContactForm();
</script>
