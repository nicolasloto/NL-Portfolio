<section
  id="contact"
  class="surface-panel js-foil backdrop-blur-lg rounded-3xl p-8 shadow-xl border border-white/30"
>
  <h3 class="text-2xl font-semibold text-white mb-6">Get in Touch</h3>

  <div class="grid md:grid-cols-[1.35fr_0.95fr] gap-8 items-start">
    <form
      id="contact-form"
      action="/api/contact"
      method="POST"
      class="space-y-6"
      novalidate
    >
      <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" />

      <div>
        <label
          for="name"
          class="block text-sm font-medium text-white/90 mb-2"
        >
          Name
        </label>
        <input
          type="text"
          id="name"
          name="name"
          class="field-control w-full px-4 py-3 text-white placeholder:text-white/60"
          placeholder="Your name"
          minlength="2"
          maxlength="120"
          pattern="^[A-Za-zÀ-ÖØ-öø-ÿ0-9.' -]{2,120}$"
          title="Please use 2-120 valid characters."
          required
        />
        <p id="name-error" class="mt-2 text-xs text-rose-300/90 min-h-4" aria-live="polite"></p>
      </div>

      <div>
        <label
          for="email"
          class="block text-sm font-medium text-white/90 mb-2"
        >
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          class="field-control w-full px-4 py-3 text-white placeholder:text-white/60"
          placeholder="your@email.com"
          maxlength="200"
          inputmode="email"
          autocapitalize="off"
          spellcheck="false"
          required
        />
        <p id="email-error" class="mt-2 text-xs text-rose-300/90 min-h-4" aria-live="polite"></p>
        <div id="email-suggestions" class="hidden mt-2 flex-wrap gap-2">
          <button type="button" data-domain="gmail.com" class="contact-chip px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-emerald-200/60 focus-visible:ring-2 focus-visible:ring-emerald-200/35">gmail.com</button>
          <button type="button" data-domain="outlook.com" class="contact-chip px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-emerald-200/60 focus-visible:ring-2 focus-visible:ring-emerald-200/35">outlook.com</button>
          <button type="button" data-domain="hotmail.com" class="contact-chip px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-emerald-200/60 focus-visible:ring-2 focus-visible:ring-emerald-200/35">hotmail.com</button>
          <button type="button" data-domain="icloud.com" class="contact-chip px-2 py-1 text-xs rounded-full bg-white/10 border border-white/35 text-white/85 hover:text-white hover:border-emerald-200/60 focus-visible:ring-2 focus-visible:ring-emerald-200/35">icloud.com</button>
        </div>
      </div>

      <div>
        <label
          for="message"
          class="block text-sm font-medium text-white/90 mb-2"
        >
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          class="field-control w-full px-4 py-3 text-white placeholder:text-white/60 resize-none"
          placeholder="Your message..."
          minlength="10"
          maxlength="5000"
          required></textarea>
        <p id="message-error" class="mt-2 text-xs text-rose-300/90 min-h-4" aria-live="polite"></p>
      </div>

      <div class="mt-6">
        <button
          type="submit"
          data-idle-label="Send Message"
          data-loading-label="Sending..."
          class="contact-send-btn w-full text-white font-medium px-6 py-3 rounded-xl border border-white/20 shadow-[0_8px_20px_rgba(0,0,0,0.25)] focus-visible:ring-2 focus-visible:ring-emerald-200/35"
        >
          Send Message
        </button>
        <p id="contact-feedback" class="mt-3 text-sm text-white/80 min-h-5" role="status" aria-live="polite" aria-atomic="true"></p>
      </div>
    </form>

    <div class="w-full md:max-w-[26rem] md:justify-self-end flex flex-col gap-4">
      <div class="hover-accent-card js-foil surface-card rounded-2xl p-6 border border-white/20">
        <h4 class="text-lg font-medium text-white mb-4">
          Contact Information
        </h4>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <div
              class="info-icon-chip"
              aria-label="Email"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"
                ></path>
                <path
                  d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"
                ></path>
              </svg>
            </div>
            <a
              href="mailto:lotohectornicolas@gmail.com"
              class="contact-link text-white/75 hover:text-emerald-200"
            >
              lotohectornicolas@gmail.com
            </a>
          </div>

          <div class="flex items-center gap-3">
            <div
              class="info-icon-chip"
              aria-label="Phone"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  fill-rule="evenodd"
                  d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <a
              href="tel:+5493855374055"
              class="contact-link text-white/75 hover:text-emerald-200"
            >
              +54 9 348 467-0283
            </a>
          </div>

          <div class="flex items-center gap-3">
            <div
              class="info-icon-chip"
              aria-label="Location"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 text-white/85"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white/75">Buenos Aires, Argentina</span>
          </div>
        </div>
      </div>

      <div class="hover-accent-card js-foil surface-card rounded-2xl p-6 border border-white/20">
        <h4 class="text-lg font-medium text-white mb-4">Availability</h4>
        <div class="space-y-2 text-white/75">
          <p>Monday - Friday</p>
          <p class="font-medium text-white">07:00 - 23:00 (GMT -3)</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initContactForm } from "../scripts/contactForm";
  initContactForm();
</script>

<style>
  #contact {
    --contact-ease: cubic-bezier(0.22, 1, 0.36, 1);
  }

  #contact .field-control {
    background: rgba(24, 24, 27, 0.72);
    border-color: rgba(113, 113, 122, 0.58);
    transition:
      border-color 220ms var(--contact-ease),
      box-shadow 220ms var(--contact-ease),
      background-color 220ms var(--contact-ease);
  }

  #contact .field-control::placeholder {
    color: rgba(228, 228, 231, 0.56);
  }

  #contact .field-control:focus {
    background: rgba(10, 24, 20, 0.88);
    border-color: rgba(110, 231, 183, 0.78);
    box-shadow: 0 0 0 2px rgba(110, 231, 183, 0.22);
  }

  .contact-chip,
  .contact-link {
    transition:
      color 220ms var(--contact-ease),
      border-color 220ms var(--contact-ease),
      background-color 220ms var(--contact-ease),
      opacity 220ms var(--contact-ease);
  }

  .contact-send-btn {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(120deg, rgba(16, 185, 129, 0.18), rgba(16, 185, 129, 0) 52%),
      linear-gradient(90deg, rgba(39, 39, 42, 0.95), rgba(5, 46, 35, 0.95), rgba(39, 39, 42, 0.95));
    transition:
      border-color 220ms var(--contact-ease),
      box-shadow 220ms var(--contact-ease),
      transform 220ms var(--contact-ease),
      filter 220ms var(--contact-ease);
    animation: btn-idle-breathe 4.2s ease-in-out infinite;
  }

  .contact-send-btn::before {
    content: "";
    position: absolute;
    inset: -130%;
    z-index: -1;
    border-radius: 999px;
    opacity: 0.35;
    transform: scale(0.55);
    background: radial-gradient(
      circle,
      rgba(110, 231, 183, 0.38) 0%,
      rgba(110, 231, 183, 0.12) 32%,
      rgba(110, 231, 183, 0) 66%
    );
    transition: opacity 260ms ease, transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
    animation: btn-idle-ripple 4.2s ease-in-out infinite;
  }

  .contact-send-btn::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.1;
    background: linear-gradient(90deg, transparent, rgba(167, 243, 208, 0.14), transparent);
    transform: translateX(-120%);
    transition: opacity 180ms var(--contact-ease);
    animation: btn-idle-sheen 6s linear infinite;
  }

  .contact-send-btn:hover {
    border-color: rgba(167, 243, 208, 0.62);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.34);
    filter: brightness(1.02);
  }

  .contact-send-btn:hover::before,
  .contact-send-btn:focus-visible::before {
    opacity: 0.55;
    transform: scale(0.82);
  }

  .contact-send-btn:hover::after,
  .contact-send-btn:focus-visible::after {
    opacity: 0.18;
    animation-duration: 3.2s;
  }

  .contact-send-btn:active {
    transform: translateY(1px) scale(0.995);
  }

  @keyframes btn-idle-sheen {
    from {
      transform: translateX(-120%);
    }
    to {
      transform: translateX(120%);
    }
  }

  @keyframes btn-idle-breathe {
    0%,
    100% {
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.24);
    }
    50% {
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.3);
    }
  }

  @keyframes btn-idle-ripple {
    0%,
    100% {
      opacity: 0.32;
      transform: scale(0.52);
    }
    50% {
      opacity: 0.42;
      transform: scale(0.66);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-send-btn,
    .contact-send-btn::before,
    .contact-send-btn::after {
      transition: none;
      animation: none;
    }
  }
</style>


