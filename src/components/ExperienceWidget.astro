---
interface Experience {
  title: string;
  company: string;
  period: string;
  description: string[];
  technologies: string[];
}

interface Education {
  degree: string;
  school: string;
  period: string;
  achievements: string[];
}

const experiences: Experience[] = [
  {
    title: "PHP Developer",
    company: "Productora Imaginar",
    period: "Oct 24 - Dec 24",
    description: [
      "Developed management tools for schedules and shifts, as well as a rental system with owners and properties as the main attributes. Utilized collaborative tools such as Slack, Bitbucket, and Jira for project management and version control.",
    ],
    technologies: ["PHP", "Laravel", "Livewire", "Docker", "WSL"],
  },
  {
    title: "Product Manager",
    company: "Quality Wines + ITSE",
    period: "Jul 23 - Dic 24",
    description: [
      "Led the development of a management system and online store for Quality Bar as part of a professional internship.",
    ],
    technologies: ["Figma", "Notion", "React", "Tailwind", "Node.js"],
  },
];

const education: Education[] = [
  {
    degree: "Advanced Technical Degree in Software Development",
    school: "ITSE - Instituto Tecnológico de Santiago del Estero",
    period: "2023 - 2024",
    achievements: [
      "Software development using multiple languages",
      "Critical thinking for real-world issues",
      "Final Grade Average: 8.96/10",
    ],
  },
  {
    degree: "English Teaching Degree",
    school: "ISFD Nº 1 - Instituto Superior de Formación Docente Nº 1",
    period: "2018 - 2022",
    achievements: [
      "Advanced grammar, phonetics, and communication",
      "Digital tools for teaching",
      "Evaluating student progress effectively",
    ],
  },
  {
    degree: "Technical Degree in Graphic Design",
    school: "Instituto Superior San Jorge",
    period: "2015 - 2017",
    achievements: [
      "Innovative design solutions",
      "Logo and identity creation",
      "Image manipulation and retouching",
    ],
  },
];
---

<div class="space-y-8">
  <section
    class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30"
  >
    <h3 class="text-2xl font-semibold text-orange-900 mb-6">Work Experience</h3>
    <div class="space-y-6">
      {
        experiences.map((exp) => (
          <article class="border-l-2 border-orange-500 pl-4 pb-6">
            <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
              <div>
                <h4 class="text-xl font-medium text-orange-900">{exp.title}</h4>
                <p class="text-orange-800">{exp.company}</p>
              </div>
              <span class="text-sm text-orange-800 bg-orange-100 px-3 py-1 rounded-full whitespace-nowrap">
                {exp.period}
              </span>
            </div>
            <ul class="list-disc list-inside text-orange-800 mb-3 space-y-1">
              {exp.description.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2">
              {exp.technologies.map((tech) => (
                <span class="px-3 py-1 bg-orange-100 text-orange-800 rounded-full text-sm">
                  {tech}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section
    class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30"
  >
    <h3 class="text-2xl font-semibold text-orange-900 mb-6">Education</h3>
    <div class="space-y-6">
      {
        education.map((edu) => (
          <article class="border-l-2 border-orange-500 pl-4 pb-6">
            <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
              <div>
                <h4 class="text-xl font-medium text-orange-900">
                  {edu.degree}
                </h4>
                <p class="text-orange-800">{edu.school}</p>
              </div>
              <span class="text-sm text-orange-800 bg-orange-100 px-3 py-1 rounded-full whitespace-nowrap">
                {edu.period}
              </span>
            </div>
            <ul class="list-disc list-inside text-orange-800 space-y-1">
              {edu.achievements.map((achievement) => (
                <li>{achievement}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>
</div>
