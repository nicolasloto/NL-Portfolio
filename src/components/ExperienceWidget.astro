---
interface Experience {
  title: string;
  company: string;
  period: string;
  description: string[];
  technologies: string[];
}

interface Education {
  degree: string;
  school: string;
  period: string;
  achievements: string[];
}

const experiences: Experience[] = [
  {
    title: "Frontend Developer",
    company: "Oasis",
    period: "Jan 2026 - Present",
    description: [
      "",
    ],
    technologies: ["React", "Tailwind", "TypeScript", "Figma", "Jira"],
  },  {
    title: "Frontend Developer",
    company: "Imaginar",
    period: "Oct 2024 - Dec 2024",
    description: [
      "Developed tools for schedule and shift management, plus a rental system for owners and properties. Used Slack, Bitbucket, and Jira for team collaboration and version control.",
    ],
    technologies: ["PHP", "Laravel", "Livewire", "Docker", "WSL"],
  },
  {
    title: "Product Manager",
    company: "Quality Wines",
    period: "Jul 2023 - Dec 2024",
    description: [
      "Led development of a management system and online store for Quality Bar as part of a professional internship.",
    ],
    technologies: ["Figma", "Notion", "React", "Tailwind", "Node.js"],
  },
];

const education: Education[] = [
  {
    degree: "🎓 Higher Technician Degree in Software Development",
    school: "ITSE - Instituto Tecnológico de Santiago del Estero",
    period: "2023 - 2024",
    achievements: [
      "Software development using multiple languages",
      "Critical thinking for real-world issues",
      "Final grade average: 8.96/10",
    ],
  },
  {
    degree: "🇬🇧 English Teaching Studies",
    school: "ISFD Nº 1 - Instituto Superior de Formación Docente No. 1",
    period: "2018 - 2022",
    achievements: [
      "Advanced grammar, phonetics, and communication",
      "Digital tools for teaching",
      "Effective student progress assessment",
    ],
  },
  {
    degree: "🎨 Graphic Design Studies",
    school: "Instituto Superior San Jorge",
    period: "2015 - 2017",
    achievements: [
      "Innovative design solutions",
      "Logo and visual identity creation",
      "Image manipulation and retouching",
    ],
  },
];
---

<div class="space-y-8">
  <section
    class="surface-panel js-foil backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30"
  >
    <h3 class="text-2xl font-semibold text-white mb-6">Work Experience</h3>
    <div class="space-y-6">
      {
        experiences.map((exp) => (
          <article class="group border-l-2 border-white/25 pl-4 pb-6">
            <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
              <div>
                <h4 class="text-xl font-medium text-white">{exp.title}</h4>
                <p class="text-white/75">{exp.company}</p>
              </div>
              <span class="text-sm text-white bg-zinc-700 border border-zinc-500 px-3 py-1 rounded-full whitespace-nowrap transition-colors duration-300 group-hover:bg-emerald-800/85 group-hover:border-emerald-300/60">
                {exp.period}
              </span>
            </div>
            <ul class="list-disc list-inside text-white/70 mb-3 space-y-1">
              {exp.description.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2">
              {exp.technologies.map((tech) => (
                <span class="px-3 py-1 bg-white/10 text-white/85 border border-white/20 rounded-full text-sm transition-colors duration-300 group-hover:border-emerald-300/60">
                  {tech}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section
    class="surface-panel js-foil backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30"
  >
    <h3 class="text-2xl font-semibold text-white mb-6">Education</h3>
    <div class="space-y-6">
      {
        education.map((edu) => (
          <article class="group border-l-2 border-white/25 pl-4 pb-6">
            <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
              <div>
                <h4 class="text-xl font-medium text-white">
                  {edu.degree}
                </h4>
                <p class="text-white/75">{edu.school}</p>
              </div>
              <span class="text-sm text-white bg-zinc-700 border border-zinc-500 px-3 py-1 rounded-full whitespace-nowrap transition-colors duration-300 group-hover:bg-emerald-800/70 group-hover:border-emerald-300/50">
                {edu.period}
              </span>
            </div>
            <ul class="list-disc list-inside text-white/70 space-y-1">
              {edu.achievements.map((achievement) => (
                <li>{achievement}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>
</div>
