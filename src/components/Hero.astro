---
import Scene3D from "./Scene3D";
import { Image } from "astro:assets";
import pfp from "/src/assets/pfp.jpg";
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <div class="absolute inset-0 z-0">
    <Scene3D client:visible />
  </div>

  <div class="container mx-auto px-4 z-10">
    <div
      class="max-w-4xl mx-auto text-center bg-white/20 backdrop-blur-sm rounded-3xl p-10 shadow-md shadow-black-500/10 border border-white/30 border-opacity-50 relative overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-gradient-to-r from-white/10 via-transparent to-white/5 pointer-events-none"
      >
      </div>

      <div class="flex flex-col items-center mb-6">
        <button
          id="pfp-btn"
          type="button"
          aria-label="Open profile image in modal"
          class="w-36 h-36 rounded-full border-2 border-white/40 shadow-2xl mb-4 overflow-hidden bg-gradient-to-br from-white/10 to-slate-900 transition-all duration-300 ease-out hover:border-white/70 hover:shadow-[0_0_24px_rgba(255,255,255,0.2)] cursor-zoom-in focus:outline-none"
        >
          <Image
            src={pfp}
            alt="Profile photo of Nicolas Loto"
            class="w-full h-full object-cover"
            width={800}
            height={800}
            unoptimized
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </button>

        <h1
          class="text-4xl md:text-7xl font-normal normal-case mb-4 text-white font-pixel"
          style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
        >
          Nicolás Loto
        </h1>

        <h2
          class="text-xl md:text-3xl text-white/90 mb-6 font-normal normal-case tracking-[0.06em] font-pixel"
          style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
        >
          Frontend | UX/UI
        </h2>
      </div>

      <div class="flex gap-6 justify-center">
        <a
          href="/projects"
          class="bg-white/20 text-white px-6 py-3 md:px-8 md:py-4 rounded-full hover:bg-white/30 transition-colors backdrop-blur-sm border border-white/40 shadow-lg shadow-black-500/10 font-mono tracking-wide uppercase text-sm"
          aria-label="View my projects"
        >
          View My Work
        </a>
        <a
          href="#contact"
          class="bg-white text-black px-6 py-3 md:px-8 md:py-4 rounded-full hover:bg-gray-200 transition-colors shadow-lg shadow-black-500/30 font-mono tracking-wide uppercase text-sm"
          aria-label="Contact me"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-16 md:bottom-16 left-1/2 transform -translate-x-1/2 flex flex-col items-center -space-y-5"
  >
    <div class="animate-pulse-bounce">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 md:h-12 md:w-12 text-slate-300 drop-shadow-sm"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
    <div class="animate-pulse-bounce animation-delay-500">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 md:h-12 md:w-12 text-slate-300 drop-shadow-sm"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </div>

  <div
    id="pfp-modal"
    class="hidden fixed inset-0 bg-black/85 z-50 flex items-center justify-center p-6"
    role="dialog"
    aria-hidden="true"
    aria-modal="true"
  >
    <div id="pfp-modal-backdrop" class="absolute inset-0"></div>

    <div class="relative z-10 max-w-[95vw] max-h-[95vh]">
      <button
        id="pfp-modal-close"
        aria-label="Close image"
        class="absolute -top-3 -right-3 z-20 bg-black/60 text-white rounded-full w-10 h-10 flex items-center justify-center text-xl hover:bg-white hover:text-black transition-colors focus:outline-none"
      >
        x
      </button>

      <img
        id="pfp-modal-img"
        src=""
        alt="Expanded photo of Nicolas Loto"
        class="block max-w-full max-h-[85vh] rounded-3xl shadow-2xl border border-white/20 object-contain"
      />
    </div>
  </div>

  <script is:inline type="module">
    (function () {
      const openButtonSelector = "#pfp-btn";
      const modal = document.getElementById("pfp-modal");
      const modalImg = document.getElementById("pfp-modal-img");
      const closeBtn = document.getElementById("pfp-modal-close");
      const backdrop = document.getElementById("pfp-modal-backdrop");

      function openModalWithSrc(src) {
        if (!modal || !modalImg) return;
        modalImg.src = src || "";
        modal.classList.remove("hidden");
        modal.setAttribute("aria-hidden", "false");
        document.documentElement.style.overflow = "hidden";
        document.body.style.overflow = "hidden";
      }

      function closeModal() {
        if (!modal || !modalImg) return;
        modal.classList.add("hidden");
        modal.setAttribute("aria-hidden", "true");
        modalImg.src = "";
        document.documentElement.style.overflow = "";
        document.body.style.overflow = "";
      }

      document.addEventListener("click", (e) => {
        const btn = e.target.closest(openButtonSelector);
        if (btn) {
          const img = btn.querySelector("img");
          const src = img?.currentSrc || img?.src || img?.getAttribute("src");
          if (!src) return;
          openModalWithSrc(src);
        }

        if (e.target === backdrop) closeModal();
      });

      if (closeBtn) closeBtn.addEventListener("click", () => closeModal());

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
      });

      const obs = new MutationObserver(() => {
        if (!modal) return;
        if (!modal.classList.contains("hidden")) {
          const focusTarget = document.getElementById("pfp-modal-close");
          focusTarget?.focus();
        }
      });

      if (modal) {
        obs.observe(modal, { attributes: true, attributeFilter: ["class"] });
      }
    })();
  </script>
</section>
