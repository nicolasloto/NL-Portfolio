---
import DitherBackground from "./DitherBackground.astro";
import { heroEyeAscii } from "../data/heroAscii";
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <DitherBackground class="absolute inset-0 z-0" intensity="medium" />

  <div class="container mx-auto px-4 z-10">
    <div class="max-w-4xl mx-auto text-center bg-black/35 rounded-3xl p-8 md:p-10 shadow-2xl shadow-black/35 border border-white/20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-white/5 via-transparent to-white/0 pointer-events-none"></div>

      <div class="flex flex-col items-center">
        <pre
          aria-label="ASCII eye"
          class="w-fit mx-auto mb-3 p-2 md:p-3 rounded-xl border border-emerald-400/35 bg-black/70 text-emerald-300 text-left text-[4px] md:text-[6px] leading-[1] shadow-xl select-text whitespace-pre"
          style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace; letter-spacing: 0; font-variant-ligatures: none; text-rendering: geometricPrecision;"
        >{heroEyeAscii}</pre>

        <h1
          class="text-5xl md:text-8xl font-normal normal-case mb-2 text-white font-pixel leading-none"
          style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
        >
          Nicolás Loto
        </h1>

        <h2
          class="text-lg md:text-2xl text-white/75 font-normal normal-case tracking-[0.04em] font-pixel"
          style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
        >
          Frontend | UX/UI
        </h2>
      </div>
    </div>
  </div>

  <div class="hero-scroll-anchor absolute left-1/2 -translate-x-1/2 z-10 pointer-events-none">
    <div
      class="hero-scroll-cue inline-flex flex-col items-center gap-1 text-white/65"
      aria-hidden="true"
    >
      <span
        class="text-[10px] tracking-[0.22em] uppercase"
        style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
      >
        Scroll
      </span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
      </svg>
    </div>
  </div>

  <div class="hero-bottom-fade" aria-hidden="true"></div>
  <div class="hero-bottom-seam" aria-hidden="true"></div>
</section>

<style>
  .hero-bottom-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: clamp(120px, 22vh, 240px);
    z-index: 5;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(7, 8, 8, 0) 0%,
      rgba(7, 8, 8, 0.3) 30%,
      rgba(7, 8, 8, 0.72) 68%,
      rgba(8, 9, 10, 0.96) 100%
    );
  }

  .hero-bottom-seam {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1px;
    z-index: 6;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.12);
  }

  .hero-scroll-anchor {
    bottom: calc(env(safe-area-inset-bottom, 0px) + 4rem);
  }

  @media (max-width: 768px) {
    .hero-scroll-anchor {
      bottom: calc(env(safe-area-inset-bottom, 0px) + 5rem);
    }
  }

  .hero-scroll-cue {
    animation: cueFloat 2.4s ease-in-out infinite;
  }

  @keyframes cueFloat {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    50% {
      transform: translateY(4px);
      opacity: 1;
    }
  }
</style>
