---
import Scene3D from "./Scene3D";
import { Image } from "astro:assets";
import pfp from "/src/assets/pfp.jpg";
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <div class="absolute inset-0 z-0">
    <Scene3D client:load />
  </div>

  <div class="container mx-auto px-4 z-10">
    <div
      class="max-w-4xl mx-auto text-center bg-white/20 backdrop-blur-sm rounded-3xl p-10 shadow-md shadow-black-500/10 border border-white/30 border-opacity-50 relative overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-gradient-to-r from-orange-500/10 to-transparent opacity-33 pointer-events-none"
      >
      </div>

      <div class="flex flex-col items-center mb-6 animate-fade-in">
        <!-- Botón envolvente: más fiable que depender directamente del id del <img> -->
        <button
          id="pfp-btn"
          type="button"
          aria-label="Abrir imagen de perfil en modal"
          class="w-36 h-36 rounded-full border-4 border-white/50 shadow-2xl mb-4 overflow-hidden bg-gradient-to-br from-orange-100 to-orange-50 hover:scale-105 transition-transform cursor-zoom-in focus:outline-none"
        >
          <Image
            src={pfp}
            alt="Foto de perfil de Nicolás Loto"
            class="w-full h-full object-cover"
            width={800}
            height={800}
            unoptimized
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </button>

        <h1
          class="text-4xl md:text-7xl font-bold mb-4 text-black"
          style="text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);"
        >
          Nicolás Loto
        </h1>

        <h2
          class="text-2xl md:text-4xl text-orange-600 mb-6 font-medium"
          style="text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);"
        >
          Frontend Dev | UX/UI Design
        </h2>
      </div>

      <div
        class="flex gap-6 justify-center animate-slide-up"
        style="animation-delay: 200ms;"
      >
        <a
          href="/projects"
          class="bg-white/20 text-orange-800 px-6 py-3 md:px-8 md:py-4 rounded-full hover:bg-white/30 transition-colors backdrop-blur-sm border border-white/30 shadow-lg shadow-black-500/10"
          aria-label="Ver mis proyectos"
        >
          View My Work
        </a>
        <a
          href="#contact"
          class="bg-orange-600 text-white px-6 py-3 md:px-8 md:py-4 rounded-full hover:bg-orange-700 transition-colors shadow-lg shadow-black-500/30"
          aria-label="Contactarme"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-16 md:bottom-16 left-1/2 transform -translate-x-1/2 flex flex-col items-center -space-y-5"
  >
    <div class="animate-pulse-bounce">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 md:h-12 md:w-12 text-slate-300 drop-shadow-sm"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
    <div class="animate-pulse-bounce animation-delay-500">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8 md:h-12 md:w-12 text-slate-300 drop-shadow-sm"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
  </div>

  <!-- Modal ampliación -->
  <div
    id="pfp-modal"
    class="hidden fixed inset-0 bg-black/85 z-50 flex items-center justify-center p-6"
    role="dialog"
    aria-hidden="true"
    aria-modal="true"
  >
    <!-- fondo (para detectar clicks fuera) -->
    <div id="pfp-modal-backdrop" class="absolute inset-0"></div>

    <div class="relative z-10 max-w-[95vw] max-h-[95vh]">
      <button
        id="pfp-modal-close"
        aria-label="Cerrar imagen"
        class="absolute -top-3 -right-3 z-20 bg-black/60 text-white rounded-full w-10 h-10 flex items-center justify-center text-xl hover:bg-orange-500 transition-colors focus:outline-none"
      >
        ✕
      </button>

      <img
        id="pfp-modal-img"
        src=""
        alt="Foto ampliada de Nicolás Loto"
        class="block max-w-full max-h-[85vh] rounded-3xl shadow-2xl border border-white/20 object-contain"
      />
    </div>
  </div>

  <!-- Script robusto: delegación, currentSrc, Escape key -->
  <script is:inline type="module">
    (function () {
      // DEBUG: quitar o comentar en producción
      // console.log('pfp modal script init');

      const openButtonSelector = "#pfp-btn";
      const modal = document.getElementById("pfp-modal");
      const modalImg = document.getElementById("pfp-modal-img");
      const closeBtn = document.getElementById("pfp-modal-close");
      const backdrop = document.getElementById("pfp-modal-backdrop");

      function openModalWithSrc(src) {
        if (!modal || !modalImg) return;
        modalImg.src = src || "";
        modal.classList.remove("hidden");
        modal.setAttribute("aria-hidden", "false");
        // lock scroll
        document.documentElement.style.overflow = "hidden";
        document.body.style.overflow = "hidden";
      }

      function closeModal() {
        if (!modal) return;
        modal.classList.add("hidden");
        modal.setAttribute("aria-hidden", "true");
        modalImg.src = "";
        // restore scroll
        document.documentElement.style.overflow = "";
        document.body.style.overflow = "";
      }

      // Delegación: escucha clicks en documento para mayor robustez ante re-renders
      document.addEventListener("click", (e) => {
        const btn = e.target.closest(openButtonSelector);
        if (btn) {
          // buscamos la <img> dentro del botón generado por <Image />
          const img = btn.querySelector("img");
          const src = img?.currentSrc || img?.src || img?.getAttribute("src");
          if (!src) {
            console.warn("No se encontró src de la imagen de perfil.");
            return;
          }
          openModalWithSrc(src);
        }

        // cierre por click en el backdrop (detecta clicks fuera del contenido)
        if (e.target === backdrop) {
          closeModal();
        }
      });

      // cierre por botón ✕
      if (closeBtn) {
        closeBtn.addEventListener("click", () => closeModal());
      }

      // teclado: Escape para cerrar
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
      });

      // accesibilidad: si el modal se abre, enfocar el botón de cierre
      const obs = new MutationObserver(() => {
        if (!modal) return;
        if (!modal.classList.contains("hidden")) {
          const focusTarget = document.getElementById("pfp-modal-close");
          focusTarget?.focus();
        }
      });
      if (modal) {
        obs.observe(modal, { attributes: true, attributeFilter: ["class"] });
      }
    })();
  </script>
</section>
