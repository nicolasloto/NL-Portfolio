---
import Scene3D from "./Scene3D";
import { heroEyeAscii } from "../data/heroAscii";
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0 hidden md:block">
    <Scene3D client:media="(min-width: 768px)" />
  </div>
  <div class="absolute inset-0 z-0 md:hidden hero-mobile-bg"></div>
  <div class="absolute inset-0 z-0 md:hidden hero-mobile-grid"></div>

  <div class="container mx-auto px-4 z-10">
    <div class="max-w-4xl mx-auto text-center bg-black/35 rounded-3xl p-8 md:p-10 shadow-2xl shadow-black/35 border border-white/20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-white/5 via-transparent to-white/0 pointer-events-none"></div>

      <div class="flex flex-col items-center">
        <pre
          aria-label="ASCII eye"
          class="w-fit mx-auto mb-3 p-2 md:p-3 rounded-xl border border-emerald-400/35 bg-black/70 text-emerald-300 text-left text-[4px] md:text-[6px] leading-[1] shadow-xl select-text whitespace-pre"
          style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace; letter-spacing: 0; font-variant-ligatures: none; text-rendering: geometricPrecision;"
        >{heroEyeAscii}</pre>

        <h1
          class="text-5xl md:text-8xl font-normal normal-case mb-2 text-white font-pixel leading-none"
          style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
        >
          Nicolás Loto
        </h1>

        <h2
          class="text-lg md:text-2xl text-white/75 font-normal normal-case tracking-[0.04em] font-pixel"
          style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
        >
          Frontend | UX/UI
        </h2>
      </div>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10 pointer-events-none">
    <div
      class="hero-scroll-cue inline-flex flex-col items-center gap-1 text-white/65"
      aria-hidden="true"
    >
      <span
        class="text-[10px] tracking-[0.22em] uppercase"
        style="font-family: var(--font-geist-pixel-grid), 'Geist Mono', monospace;"
      >
        Scroll
      </span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" />
      </svg>
    </div>
  </div>
</section>

<style>
  .hero-scroll-cue {
    animation: cueFloat 2.4s ease-in-out infinite;
  }

  @keyframes cueFloat {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    50% {
      transform: translateY(4px);
      opacity: 1;
    }
  }
</style>

<style is:global>
  .hero-mobile-bg {
    background:
      radial-gradient(circle at 25% 18%, rgba(255, 255, 255, 0.08), transparent 34%),
      radial-gradient(circle at 80% 8%, rgba(255, 255, 255, 0.06), transparent 36%),
      linear-gradient(180deg, #030303 0%, #060606 100%);
  }

  .hero-mobile-grid {
    opacity: 0.22;
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
    background-size: 26px 26px;
  }
</style>
