---
import { projects } from "../data/project";
import type { Project } from "../types/project";
import { Image } from "astro:assets";

const featuredProjects: Project[] = projects;
---

<div
  class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30"
>
  <div class="md:flex justify-between items-center mb-6">
    <h3 class="text-2xl font-semibold text-white">Featured Projects</h3>
    <a
      href="/projects"
      class="text-white/75 hover:text-white transition-colors text-sm"
      aria-label="View all projects"
    >
      View all projects</a>
  </div>
  <div class="grid gap-6">
    {
      featuredProjects.map((project) => (
        <article
          key={project.id}
          class="group hover-accent-card block bg-white/20 p-4 sm:p-6 rounded-2xl hover:shadow-lg transition-all duration-300 border border-white/20"
        >
          <a
            href={project.demoUrl}
            class="flex flex-col sm:flex-row gap-4 sm:gap-6"
            aria-label={`View ${project.title} project`}
          >
            <Image
              src={project.image}
              alt={project.title}
              width={400}
              height={400}
              class="w-full sm:w-24 h-48 sm:h-24 rounded-xl object-cover"
              loading="lazy"
            />
            <div class="flex-1">
              <h4 class="text-xl font-medium text-white mb-2 transition-colors duration-300 group-hover:text-cyan-200">
                {project.title}
              </h4>
              <p class="text-white/65 mb-3 transition-colors duration-300 group-hover:text-white/90">{project.description}</p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tech, techIndex) => {
                  const hoverColor =
                    techIndex % 3 === 0
                      ? "group-hover:text-cyan-200 group-hover:border-cyan-300/70"
                      : techIndex % 3 === 1
                        ? "group-hover:text-fuchsia-200 group-hover:border-fuchsia-300/70"
                        : "group-hover:text-amber-200 group-hover:border-amber-300/70";

                  return (
                    <span
                      class={`px-3 py-1 bg-white/10 text-white/85 border border-white/30 rounded-full text-sm transition-colors duration-300 ${hoverColor}`}
                      aria-label={`Technology: ${tech}`}
                    >
                      {tech}
                    </span>
                  );
                })}
              </div>
            </div>
          </a>
        </article>
      ))
    }
  </div>
</div>

