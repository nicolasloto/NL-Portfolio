---
import { projects } from '../data/project';
import type { Project } from '../types/project';
import { Image } from 'astro:assets';

const featuredProjects: Project[] = projects;
---

<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30">
  <div class="md:flex justify-between items-center mb-6">
    <h3 class="text-2xl font-semibold text-orange-900">Featured Projects</h3>
    <a
      href="/projects"
      class="text-orange-600 hover:text-orange-800 transition-colors text-sm"
      aria-label="View all projects"
    >
      View all projects →
    </a>
  </div>
  <div class="grid gap-6">
    {
      featuredProjects.map((project) => (
        <article
          key={project.id}
          class="block bg-gradient-to-br from-orange-50 to-white p-4 sm:p-6 rounded-2xl hover:shadow-lg transition-all duration-300"
        >
          <a
            href={project.demoUrl}
            class="flex flex-col sm:flex-row gap-4 sm:gap-6"
            aria-label={`View ${project.title} project`}
          >
            <Image
              src={project.image}
              alt={project.title}
              width={200}
              height={200}
              class="w-full sm:w-24 h-48 sm:h-24 rounded-xl object-cover"
              loading="lazy"
            />
            <div class="flex-1">
              <h4 class="text-xl font-medium text-orange-900 mb-2">{project.title}</h4>
              <p class="text-orange-600 mb-3">{project.description}</p>
              <div class="flex flex-wrap gap-2">
                {
                  project.tags.map((tech) => (
                    <span
                      class="px-3 py-1 bg-orange-100 text-orange-600 rounded-full text-sm"
                      aria-label={`Technology: ${tech}`}
                    >
                      {tech}
                    </span>
                  ))
                }
              </div>
            </div>
          </a>
        </article>
      ))
    }
  </div>
</div>