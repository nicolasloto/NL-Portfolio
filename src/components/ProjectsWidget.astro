---
import { projects } from "../data/project";
import type { Project } from "../types/project";
import ProjectCard from "./ProjectCard.astro";

const featuredProjects: Project[] = projects.slice(0, 3);
---

<div class="surface-panel js-foil backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30">
  <div class="mb-6">
    <h3 class="text-2xl font-semibold text-white">Featured Projects</h3>
  </div>
  <div class="grid gap-6">
    {
      featuredProjects.map((project) => {
        return <ProjectCard project={project} variant="list" showActions={false} />;
      })
    }
  </div>
  <div class="mt-6 pt-4 border-t border-white/15 flex justify-end">
    <a
      href="/projects"
      class="text-white/75 hover:text-white focus-visible:ring-2 focus-visible:ring-cyan-200/40 transition-colors text-sm rounded-md px-1 py-0.5"
      aria-label="View all projects"
    >
      View all projects
    </a>
  </div>
</div>
