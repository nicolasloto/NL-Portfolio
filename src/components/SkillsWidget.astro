---
interface Skill {
  name: string;
  level: "Expert" | "Advanced" | "Intermediate" | "Basic";
  icon: string;
}

const skills: Skill[] = [
  { name: "Figma", level: "Expert", icon: "🖼️" },
  { name: "Git/GitHub", level: "Expert", icon: "🐙" },
  { name: "React", level: "Advanced", icon: "⚛️" },
  { name: "Tailwind CSS", level: "Advanced", icon: "🎨" },
  { name: "JavaScript", level: "Advanced", icon: "⚡" },
  { name: "Node.js", level: "Intermediate", icon: "🟢" },
  { name: "Jira/Trello", level: "Intermediate", icon: "📋" },
  { name: "Databases", level: "Basic", icon: "🧮" },
  { name: "Docker", level: "Basic", icon: "🐳" },
  { name: "PHP", level: "Basic", icon: "🐘" },
];

const levelRowColors = {
  Expert: "bg-zinc-800/35 hover:bg-emerald-500/[0.12] hover:border-emerald-300/[0.68]",
  Advanced: "bg-zinc-800/35 hover:bg-emerald-500/[0.09] hover:border-emerald-300/[0.56]",
  Intermediate: "bg-zinc-800/35 hover:bg-emerald-500/[0.06] hover:border-emerald-300/[0.44]",
  Basic: "bg-zinc-800/35 hover:bg-emerald-500/[0.03] hover:border-emerald-300/[0.32]",
};

const levelBadgeColors = {
  Expert: "badge-expert",
  Advanced: "badge-advanced",
  Intermediate: "badge-intermediate",
  Basic: "badge-basic",
};
---

<div
  class="surface-panel js-foil backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30"
>
  <h3 class="text-2xl font-semibold mb-4 text-white">Skills</h3>
  <div class="space-y-4">
    {
      skills.map((skill) => (
        <div
          class={`group skill-row level-${skill.level.toLowerCase()} flex items-center justify-between p-3 rounded-xl transition-colors duration-200 border border-transparent ${levelRowColors[skill.level]}`}
        >
          <div class="flex items-center gap-3">
            <span class="text-xl" aria-hidden="true">
              {skill.icon}
            </span>
            <span class="font-medium text-white/90">{skill.name}</span>
          </div>
          <span
            class={`skill-badge px-3 py-1 rounded-full text-sm font-medium shadow-sm transition-colors duration-200 ${levelBadgeColors[skill.level]}`}
          >
            {skill.level}
          </span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .skill-badge {
    background: rgba(63, 63, 70, 0.95);
    color: rgba(244, 244, 245, 0.95);
    border: 1px solid rgba(113, 113, 122, 0.8);
  }

  .skill-row.level-basic:hover .skill-badge {
    background: rgba(6, 78, 59, 0.58);
    border-color: rgba(167, 243, 208, 0.5);
    color: rgba(236, 253, 245, 0.95);
  }

  .skill-row.level-intermediate:hover .skill-badge {
    background: rgba(6, 95, 70, 0.72);
    border-color: rgba(167, 243, 208, 0.6);
    color: rgba(236, 253, 245, 0.95);
  }

  .skill-row.level-advanced:hover .skill-badge {
    background: rgba(6, 120, 86, 0.84);
    border-color: rgba(167, 243, 208, 0.72);
    color: rgba(240, 253, 250, 1);
  }

  .skill-row.level-expert:hover .skill-badge {
    background: rgba(5, 150, 105, 0.95);
    border-color: rgba(167, 243, 208, 0.84);
    color: rgba(255, 255, 255, 1);
  }
</style>
