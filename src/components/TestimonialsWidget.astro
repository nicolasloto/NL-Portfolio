---
import { Image } from 'astro:assets';
import ceciliaAvatar from '../assets/cecilia-pfp.jpg';

interface Testimonial {
  content: string;
  author: string;
  role: string;
  company: string;
  avatar: typeof ceciliaAvatar;
}

const testimonials: Testimonial[] = [
  {
    content: "I had the pleasure of working with Nicolás on the Quality Wines project, where he served as Product Manager. His ability to align the team with objectives was key to our success. Nicolás motivated us, provided constant support, and his creativity and attention to detail elevated every deliverable. His passion for design and leadership left a lasting positive impact on the team.",
    author: "Andrea Cecilia López",
    role: "Backend Dev",
    company: "Quality + ITSE",
    avatar: ceciliaAvatar,
  },
];
---

<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl border border-white/30">
  <h3 class="text-2xl font-semibold text-orange-900 mb-6">What People Say</h3>
  <div class="grid md:grid-cols-2 gap-6">
    {
      testimonials.map((testimonial) => (
        <article
          class="bg-gradient-to-br from-orange-50 to-white p-6 rounded-2xl hover:shadow-lg transition-all duration-300"
          aria-labelledby={`testimonial-${testimonial.author.toLowerCase().replace(/\s+/g, '-')}`}
        >
          <div class="flex gap-4 items-start">
            <Image
              src={testimonial.avatar}
              alt={testimonial.author}
              class="w-12 h-12 rounded-full object-cover"
              width={48}
              height={48}
              loading="lazy"
            />
            <div class="flex-1">
              <p
                id={`testimonial-${testimonial.author.toLowerCase().replace(/\s+/g, '-')}`}
                class="text-orange-800/90 mb-4"
              >
                {testimonial.content}
              </p>
              <div>
                <p class="font-medium text-orange-900">{testimonial.author}</p>
                <p class="text-sm text-orange-800">
                  {testimonial.role} at {testimonial.company}
                </p>
              </div>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</div>