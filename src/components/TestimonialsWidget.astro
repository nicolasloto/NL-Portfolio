---
interface Testimonial {
  content: string;
  author: string;
  role: string;
  company: string;
  avatar: string;
}

const testimonials: Testimonial[] = [
  {
    content: "I had the pleasure of working with Nicolás during the Quality Wines project, where he played the role of Product Manager. In addition to being teammates, we studied together at the Instituto Tecnológico de Santiago del Estero, where he already stood out for his commitment and responsibility. In the project, his ability to keep the team aligned with the objectives was key to success. Nicolás not only motivated us to accomplish our tasks, but also provided us with the necessary support at every stage. His creativity, accuracy and perfectionism made the difference in every delivery, and his passion for design elevated the quality of our results. Working with him was an rewarding experience, and his leadership left a very positive mark on the team.",
    author: "Andrea Cecilia López",
    role: "Backend Dev",
    company: "Quality + ITSE",
    avatar: "src/assets/cecilia pfp.jpg"
  }
];
---
<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl">
  <h3 class="text-2xl font-semibold text-orange-900 mb-6">What People Say</h3>
  <div class="grid md:grid-cols-2 gap-6">
    {testimonials.map((testimonial) => (
      <div class="bg-gradient-to-br from-orange-50 to-white p-6 rounded-2xl">
        <div class="flex gap-4 items-start">
          <img 
            src={testimonial.avatar} 
            alt={testimonial.author}
            class="w-12 h-12 rounded-full object-cover"
          />
          <div class="flex-1">
            <p class="text-orange-800/90 mb-4">{testimonial.content}</p>
            <div>
              <p class="font-medium text-orange-900">{testimonial.author}</p>
              <p class="text-sm text-orange-800">
                {testimonial.role} at {testimonial.company}
              </p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>