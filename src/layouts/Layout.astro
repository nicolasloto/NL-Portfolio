---
import "@fontsource-variable/inter";
import "@fontsource/source-sans-pro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Nicolás' Portfolio | Web developer & UX/UI designer",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="https://ps.w.org/advance-portfolio-grid/assets/icon-256x256.png"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-apple-gray-50 text-apple-gray-500">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --accent: rgb(0, 122, 255);
    --accent-dark: rgb(0, 64, 221);
  }

  html {
    font-family: "SF Pro Display", "Inter Variable", system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    overscroll-behavior: none;
  }

@keyframes fade-up-visible {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* --- FIX FORM OVERFLOW Y BOTÓN INVISIBLE --- */
#contact {
  position: relative;
  isolation: isolate;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden; /* evita que se salga en mobile */
  box-sizing: border-box;
}

/* asegura que el grid no rompa el ancho */
#contact .grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

@media (min-width: 768px) {
  #contact .grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* evita desbordes en los inputs y textareas */
#contact input,
#contact textarea {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}
#contact a,
#contact span {
  word-break: break-word;
  overflow-wrap: anywhere;
}




/* mantiene el botón visible con animación */
#contact-form button[type="submit"] {
  opacity: 1 !important;
  visibility: visible !important;
  z-index: 10;
  transform: none !important;
  animation: fade-up-visible 0.6s ease-out 0.2s both;
  will-change: opacity;
}
