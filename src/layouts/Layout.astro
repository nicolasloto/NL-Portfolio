---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Nicolas Portfolio | Frontend Developer & UX/UI Designer",
} = Astro.props;
const pageUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();
const socialImage = Astro.site
  ? new URL("/favicon.svg", Astro.site).toString()
  : "/favicon.svg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="dark" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="canonical" href={pageUrl} />
    <link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeistPixel-Grid.woff2" as="font" type="font/woff2" crossorigin />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="text-slate-100">
    <slot />
    <script is:inline>
      (() => {
        if (!window.matchMedia("(pointer: fine)").matches) return;

        const cards = Array.from(document.querySelectorAll(".js-foil"));

        cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          card.classList.add("foil-card");
          let rafId = 0;

          card.addEventListener(
            "pointermove",
            (e) => {
              if (rafId) return;
              rafId = requestAnimationFrame(() => {
                const rect = card.getBoundingClientRect();
                const px = ((e.clientX - rect.left) / rect.width) * 100;
                const py = ((e.clientY - rect.top) / rect.height) * 100;
                card.style.setProperty("--fx", `${px}%`);
                card.style.setProperty("--fy", `${py}%`);
                rafId = 0;
              });
            },
            { passive: true }
          );

          card.addEventListener("pointerleave", () => {
            card.style.setProperty("--fx", "50%");
            card.style.setProperty("--fy", "50%");
          });
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Geist";
    src: url("/fonts/Geist-Variable.woff2") format("woff2");
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Geist Mono";
    src: url("/fonts/GeistMono-Variable.woff2") format("woff2");
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Geist Pixel Grid";
    src: url("/fonts/GeistPixel-Grid.woff2") format("woff2");
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }

  :root {
    --font-geist-pixel-grid: "Geist Pixel Grid";
    --bg-main: #050505;
    --bg-elevated: rgba(18, 18, 18, 0.78);
    --line: rgba(255, 255, 255, 0.1);
    --text-main: #f3f3f3;
    --text-muted: #b8b8b8;
    --accent: #ffffff;
    --accent-alt: #d9d9d9;
    --accent-hero: #34d399;
    --accent-hero-soft: #6ee7b7;
    --accent-hero-muted: rgba(52, 211, 153, 0.18);
    --hover-a: rgba(110, 231, 183, 0.14);
    --hover-b: rgba(167, 243, 208, 0.1);
    --hover-c: rgba(228, 228, 231, 0.1);
    --ease-standard: cubic-bezier(0.22, 1, 0.36, 1);
    --motion-fast: 220ms;
    --motion-medium: 320ms;
  }

  html {
    color-scheme: dark;
    font-family: "Geist", system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    color: var(--text-main);
    background:
      radial-gradient(circle at 20% 15%, rgba(255, 255, 255, 0.08), transparent 34%),
      radial-gradient(circle at 80% 5%, rgba(255, 255, 255, 0.06), transparent 36%),
      linear-gradient(180deg, #000 0%, var(--bg-main) 100%);
    overscroll-behavior: none;
    position: relative;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    opacity: 0.45;
    background-image:
      linear-gradient(to right, var(--line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--line) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(circle at center, black 30%, transparent 100%);
  }

  ::selection {
    background: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 3px,
      rgba(255, 255, 255, 0.02) 4px
    );
  }

  h1,
  h2 {
    font-family: var(--font-geist-pixel-grid), "Geist Mono", monospace;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  h3,
  h4,
  p,
  span,
  a,
  input,
  textarea,
  button,
  label {
    font-family: "Geist", system-ui, sans-serif;
  }

  .surface-panel,
  .surface-card,
  .bg-white\/80,
  .bg-white\/50,
  .bg-white\/20,
  .bg-white {
    background: var(--bg-elevated) !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35) !important;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      border-color var(--motion-fast) var(--ease-standard),
      box-shadow var(--motion-fast) var(--ease-standard),
      transform var(--motion-fast) var(--ease-standard);
  }


  .surface-panel:hover,
  .surface-card:hover,
  .bg-white\/80:hover,
  .bg-white\/50:hover,
  .bg-white\/20:hover,
  .bg-white:hover {
    border-color: rgba(255, 255, 255, 0.38) !important;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45) !important;
  }

  .hover-accent-card {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    transition:
      border-color var(--motion-fast) var(--ease-standard),
      box-shadow var(--motion-fast) var(--ease-standard),
      transform var(--motion-fast) var(--ease-standard);
  }

  .hover-accent-card:hover {
    border-color: rgba(255, 255, 255, 0.38) !important;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45) !important;
  }

  .field-control {
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: var(--text-main);
    outline: none;
    transition:
      border-color var(--motion-fast) var(--ease-standard),
      box-shadow var(--motion-fast) var(--ease-standard);
  }

  .field-control:focus {
    border-color: color-mix(in srgb, var(--accent-hero-soft) 85%, white 15%);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent-hero-soft) 22%, transparent);
  }

  .info-icon-chip {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
  }

  .foil-card {
    --fx: 50%;
    --fy: 50%;
    will-change: background, border-color, box-shadow;
    transition:
      border-color var(--motion-fast) var(--ease-standard),
      box-shadow var(--motion-fast) var(--ease-standard),
      filter var(--motion-fast) var(--ease-standard);
  }

  .foil-card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.16;
    transition: opacity var(--motion-fast) var(--ease-standard);
    background:
      linear-gradient(
        120deg,
        rgba(110, 231, 183, 0.16),
        rgba(228, 228, 231, 0.12),
        rgba(167, 243, 208, 0.12)
      ),
      linear-gradient(
        295deg,
        rgba(228, 228, 231, 0.12),
        rgba(110, 231, 183, 0.1),
        rgba(167, 243, 208, 0.1)
      );
    background-size: 220% 220%, 220% 220%;
    background-position: var(--fx) var(--fy), var(--fy) var(--fx);
    mix-blend-mode: screen;
    transform: scale(0.98);
    transition:
      opacity var(--motion-fast) var(--ease-standard),
      transform var(--motion-fast) var(--ease-standard);
  }

  .foil-card:hover::before {
    opacity: 0.42;
    transform: scale(1);
  }

  .text-black {
    color: var(--text-main) !important;
  }

  .glitch-text {
    position: relative;
    text-shadow: -1px 0 rgba(255, 255, 255, 0.45), 1px 0 rgba(170, 170, 170, 0.35);
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    left: 0;
    width: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .glitch-text::before {
    top: -1px;
    color: rgba(255, 255, 255, 0.45);
    clip-path: inset(0 0 45% 0);
    animation: glitch-scan 3s infinite linear alternate-reverse;
  }

  .glitch-text::after {
    top: 1px;
    color: rgba(170, 170, 170, 0.45);
    clip-path: inset(60% 0 0 0);
    animation: glitch-scan 2.6s infinite linear alternate;
  }

  @keyframes glitch-scan {
    0% { transform: translateX(0); }
    20% { transform: translateX(-2px); }
    40% { transform: translateX(2px); }
    60% { transform: translateX(-1px); }
    80% { transform: translateX(1px); }
    100% { transform: translateX(0); }
  }

  @keyframes fade-up-visible {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #contact {
    position: relative;
    isolation: isolate;
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  #contact .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    #contact .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #contact input,
  #contact textarea {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    color: var(--text-main);
    border-color: rgba(255, 255, 255, 0.26);
  }

  #contact a,
  #contact span {
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  #contact-form button[type="submit"] {
    opacity: 1 !important;
    visibility: visible !important;
    z-index: 10;
    transform: none !important;
    animation: fade-up-visible 0.6s ease-out 0.2s both;
    will-change: opacity;
  }
</style>
